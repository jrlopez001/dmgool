{
  "expo": {
    "name": "DMGooL",
    "slug": "dmgool",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "dmgool",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundColor": "#0f172a"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.bandegua.dmgool"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "cover",
          "backgroundColor": "#0f172a"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "owner": "bandegua",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "6b4bb2d2-0ba7-4f10-85f2-f2afc8b88578"
      }
    }
  }
}
